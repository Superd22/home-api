{
  "name": "home-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./apps/home-api/test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "8.0.4",
    "@nestjs/core": "8.0.4",
    "@nestjs/graphql": "8.0.2",
    "@nestjs/platform-fastify": "8.0.4",
    "@nestjs/typeorm": "8.0.1",
    "@types/axios": "0.14.0",
    "apollo-server-fastify": "3.0.2",
    "axios": "0.21.1",
    "class-transformer": "0.4.0",
    "graphql-subscriptions": "1.2.1",
    "lgtv2": "1.6.3",
    "reflect-metadata": "0.1.13",
    "rimraf": "3.0.2",
    "rxjs": "7.2.0",
    "sqlite3": "5.0.2",
    "ssh2-promise": "1.0.0",
    "tiny-json-http": "7.3.0",
    "typeorm": "0.2.34"
  },
  "devDependencies": {
    "@nestjs/cli": "8.0.2",
    "@nestjs/schematics": "8.0.2",
    "@nestjs/testing": "8.0.4",
    "@types/express": "4.17.13",
    "@types/jest": "26.0.24",
    "@types/lgtv2": "1.4.2",
    "@types/node": "14.17.5",
    "@types/supertest": "2.0.11",
    "@typescript-eslint/eslint-plugin": "4.28.4",
    "@typescript-eslint/parser": "4.28.4",
    "eslint": "7.31.0",
    "eslint-config-prettier": "8.3.0",
    "eslint-plugin-import": "2.23.4",
    "jest": "27.0.6",
    "prettier": "2.3.2",
    "supertest": "6.1.3",
    "ts-jest": "27.0.3",
    "ts-loader": "9.2.3",
    "ts-node": "10.1.0",
    "tsconfig-paths": "3.10.1",
    "typescript": "4.3.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/"
    ],
    "moduleNameMapper": {
      "@homeapi/freebox/(.*)": "<rootDir>/libs/freebox/src/$1",
      "@homeapi/freebox": "<rootDir>/libs/freebox/src",
      "@homeapi/nordvpn/(.*)": "<rootDir>/libs/nordvpn/src/$1",
      "@homeapi/nordvpn": "<rootDir>/libs/nordvpn/src",
      "@homeapi/pubsub/(.*)": "<rootDir>/libs/pubsub/src/$1",
      "@homeapi/pubsub": "<rootDir>/libs/pubsub/src",
      "@homeapi/ovpn/(.*)": "<rootDir>/libs/ovpn/src/$1",
      "@homeapi/ovpn": "<rootDir>/libs/ovpn/src",
      "@homeapi/lgtv/(.*)": "<rootDir>/libs/lgtv/src/$1",
      "@homeapi/lgtv": "<rootDir>/libs/lgtv/src"
    }
  }
}
